# Med-Verify Pro - Backend Environment Variables
PORT=5000

# MongoDB Connection String (e.g. from MongoDB Atlas)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/medverify?retryWrites=true&w=majority

# JWT Secret for Session Encryption
JWT_SECRET=your_super_secret_jwt_key_here

# SMTP Configuration for Nodemailer (Welcome Emails)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# API Keys
GOOGLE_API_KEY=your_gemini_google_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

